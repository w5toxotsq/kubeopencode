# Copyright Contributors to the KubeOpenCode project
# Local test environment secrets
#
# NOTE: The default local-dev setup uses the free opencode/big-pickle model,
# which does NOT require an API key. You can skip this file entirely for
# a quick start — just run: kubectl apply -k deploy/local-dev/
#
# If you want to use a paid model (e.g., Anthropic Claude, Google Gemini),
# follow these steps:
#   1. Copy this file: cp secrets.yaml.example secrets.yaml
#   2. Edit secrets.yaml with your real API key
#   3. Update agenttemplate.yaml to reference your chosen model
#   4. Uncomment the credentials section in agenttemplate.yaml
#   5. Apply: kubectl apply -k deploy/local-dev/
#
# The secrets.yaml file is gitignored.
---
apiVersion: v1
kind: Secret
metadata:
  name: opencode-credentials
type: Opaque
stringData:
  # OpenCode API key for AI model access
  # Get your key from: https://opencode.ai/
  OPENCODE_API_KEY: "sk-your-opencode-api-key-here"
---
apiVersion: v1
kind: Secret
metadata:
  name: git-settings
type: Opaque
stringData:
  GIT_AUTHOR_EMAIL: "test@example.com"
  GIT_AUTHOR_NAME: "Test Bot"
  GIT_COMMITTER_EMAIL: "test@example.com"
  GIT_COMMITTER_NAME: "Test Bot"
